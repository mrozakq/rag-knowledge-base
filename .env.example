# RAG Knowledge Base — zmienne środowiskowe
# Skopiuj ten plik do .env i uzupełnij wartości

# --- API Security ---
# Klucz API do autoryzacji zapytań (Bearer token)
API_KEY=

# --- CORS ---
# Dozwolone originy dla CORS, oddzielone przecinkami
# Domyślnie "*" dla dev; w produkcji podaj konkretną domenę
ALLOWED_ORIGINS=*

# --- Ollama ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- ChromaDB ---
CHROMA_HOST=http://chromadb:8000
CHROMA_COLLECTION=rag_documents

# --- RAG ---
# Liczba chunków pobieranych przy retrieval
RAG_TOP_K=5
# Rozmiar chunka (tokeny)
CHUNK_SIZE=512
# Overlap między chunkami (tokeny)
CHUNK_OVERLAP=64

# --- Open WebUI ---
# Port na którym dostępny jest Open WebUI lokalnie
OPEN_WEBUI_PORT=3000
